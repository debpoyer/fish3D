                {Faces.RIGHT, new FaceData {
                    vertices = AddTransformedVertices(FaceDataRaw.rawVertexData[Faces.RIGHT]),
                    uv = dirtUV
                } },
                {Faces.TOP, new FaceData {
                    vertices = AddTransformedVertices(FaceDataRaw.rawVertexData[Faces.TOP]),
                    uv = dirtUV
